# Development Dockerfile for CLIO Elixir Umbrella Application
FROM elixir:1.16-alpine

# Install system dependencies
RUN apk add --no-cache \
    build-base \
    git \
    nodejs \
    npm \
    postgresql-client \
    inotify-tools

# Set work directory
WORKDIR /app

# Install Hex and Rebar
RUN mix local.hex --force && \
    mix local.rebar --force

# Copy mix files
COPY mix.exs mix.lock ./
COPY apps/*/mix.exs apps/*/
COPY config config

# Install mix dependencies
RUN mix deps.get
RUN mix deps.compile

# Copy source code
COPY . .

# Create data directory for audit logs
RUN mkdir -p /app/data

# Compile the application
RUN mix compile

# Expose port
EXPOSE 4000

# Default command
CMD ["mix", "phx.server"]
