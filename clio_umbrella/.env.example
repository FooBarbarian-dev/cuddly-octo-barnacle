# CLIO Environment Configuration Template
# Copy this file to .env for development or customize for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database URL (used in production)
# Format: ecto://username:password@hostname:port/database_name
DATABASE_URL="ecto://postgres:postgres@localhost:5432/redteamlogger"

# Individual PostgreSQL settings (alternative to DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=redteamlogger
# Database pool size
POOL_SIZE=10

# =============================================================================
# ENCRYPTION & SECURITY
# =============================================================================

# JWT Secret (must be at least 32 bytes)
JWT_SECRET="your-jwt-secret-key-at-least-32-bytes-long-change-this-in-production"

# Phoenix Secret Key Base (must be at least 64 bytes)
SECRET_KEY_BASE="your-phoenix-secret-key-base-must-be-at-least-64-bytes-long-change-this-in-production-environment"

# Admin HMAC Secret (for admin proof verification)
ADMIN_SECRET="your-admin-hmac-secret-change-this-in-production"

# Field Encryption Key (64-character hex string for AES-256)
FIELD_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Cache Encryption Key (64-character hex string for AES-256)
CACHE_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Cloak Key (base64 encoded 32-byte key for database field encryption)
CLOAK_KEY="dGVzdGtleXRlc3RrZXl0ZXN0a2V5dGVzdGtleXRlcw=="

# =============================================================================
# USER CREDENTIALS
# =============================================================================

# Default admin password (change immediately after first login)
ADMIN_PASSWORD="AdminPassword123!"

# Default user password (change immediately after first login)
USER_PASSWORD="UserPassword123!"

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server hostname
HOSTNAME=localhost

# HTTP port
PORT=4000

# Unique server instance ID (auto-generated if not set)
SERVER_INSTANCE_ID="dev-instance-001"

# Data directory for audit logs and file uploads
DATA_DIR="data"

# =============================================================================
# OPTIONAL: GOOGLE OAUTH (if using Google authentication)
# =============================================================================

# Google OAuth Client ID
# GOOGLE_CLIENT_ID="your-google-client-id.googleusercontent.com"

# Google OAuth Client Secret
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google OAuth Callback URL
# GOOGLE_CALLBACK_URL="http://your-host:4000/api/auth/google/callback"

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Mix environment (dev, test, prod)
MIX_ENV=dev

# Enable development features
PHX_SERVER=true

# =============================================================================
# NOTES (PoC - convenience over security)
# =============================================================================
#
# This configuration is intentionally simplified for proof-of-concept use.
# The following security measures are SKIPPED and should be addressed before
# any real deployment:
#
# SKIPPED (SSL/TLS):
#   - No SSL for PostgreSQL connections (POSTGRES_SSL removed)
#   - No HTTPS for the web endpoint (running plain HTTP)
#   - No reverse proxy / TLS termination
#   -> In production: add a TLS-terminating proxy (nginx/traefik), set
#      ssl: true on the Repo, and update the endpoint scheme to "https".
#
# SKIPPED (secrets hardening):
#   - Keys below use weak dev defaults; rotate them for any shared environment.
#   - Generate proper keys with: openssl rand -base64 32 / openssl rand -hex 32
#
# SKIPPED (secrets management):
#   - Secrets are stored in a plain .env file.
#   -> In production: use Vault, AWS Secrets Manager, or similar.
#
# =============================================================================
